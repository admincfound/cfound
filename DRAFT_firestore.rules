rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'admin.cfound@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // 1. Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
        incoming().role == 'user' && // Default role on signup
        incoming().email == request.auth.token.email;
      allow update: if (isOwner(userId) && 
        incoming().role == existing().role && // Users cannot change their own role
        incoming().email == existing().email) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Projects
    match /projects/{projectId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // 3. Opportunities (Jobs/Internships)
    match /opportunities/{oppId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // 4. Courses
    match /courses/{courseId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // 5. Applications
    match /applications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isAdmin(); // Only admin can update status
      allow delete: if isAdmin();
    }

    // 6. Announcements
    match /announcements/{annId} {
      allow read: if resource.data.type == 'public' || (isSignedIn() && resource.data.type == 'member');
      allow write: if isAdmin();
    }
  }
}
