rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email in ['admin.cfound@gmail.com', 'admin.cfound.gmail.com'];
    }

    // ⚡ Fast Evaluation: Checks custom claims first to eliminate login hanging loops
    function isAdmin() {
      return isSignedIn() && (
        isHardcodedAdmin() ||
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // 1. Users Profile Collection
    match /users/{userId} {

      allow read: if isSignedIn() &&
        (request.auth.uid == userId || isHardcodedAdmin());

      allow create: if isSignedIn() &&
        request.auth.uid == userId;

      allow update: if isSignedIn() &&
        (request.auth.uid == userId || isHardcodedAdmin());

      allow delete: if isHardcodedAdmin();
    }

    // 2. Projects Portfolio
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Opportunities (Jobs/Internships)
    match /opportunities/{oppId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Courses Catalog
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Unified Applications & Enrollments (Matches Blueprint Model)
    // Supports matching requests to /applications, /internshipApplications, and /courseEnrollments
    match /applications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /internshipApplications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /courseEnrollments/{enrollId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 6. Corporate Announcements
    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Research Insights & Blog Posts
    match /posts/{postId} {
      allow read: if isValidId(postId) && (resource.data.status == 'active' || isAdmin());
      allow list: if isAdmin() || resource.data.status == 'active';
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 8. Global System Configuration Mapping
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system/config {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}