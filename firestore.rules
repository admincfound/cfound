rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email in ['admin.cfound.gmail.com'];
    }

    // ⚡ FIX: Fall back to custom claim first to avoid heavy database get() calls during login
    function isAdmin() {
      return isSignedIn() && (
        isHardcodedAdmin() ||
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.email is string && 
             data.role in ['user', 'admin'];
    }

    // --- Collections ---

    // 1. Users
    match /users/{userId} {
      // ⚡ FIX: Swap order so isOwner evaluated instantly without forcing isAdmin database lookup
      allow read: if isOwner(userId) || isAdmin();
      
      // ⚡ FIX: Adjusted check to allow safe OTP signups where token email might be delayed or null
      allow create: if isSignedIn() && isOwner(userId) && 
        (isHardcodedAdmin() ? incoming().role == 'admin' : incoming().role == 'user') && 
        (request.auth.token.email == null || incoming().email == request.auth.token.email);
        
      allow update: if (isOwner(userId) && 
        incoming().role == existing().role && 
        incoming().email == existing().email) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Opportunities
    match /opportunities/{oppId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Courses
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Applications & Enrollments
    match /applications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /internshipApplications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /courseEnrollments/{enrollId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 6. Announcements
    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Blog Posts
    match /posts/{postId} {
      allow read: if isValidId(postId) && (resource.data.status == 'active' || isAdmin());
      allow list: if isAdmin() || resource.data.status == 'active';
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 8. System Config
    match /system/config {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}