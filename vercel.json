{
  "rewrites": [
    {
      "source": "/job-test/:slug",
      "destination": "/api/job/:slug"
    },
    {
      "source": "/careers/:slug",
      "destination": "/api/job/:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}