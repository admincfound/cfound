{
  "rewrites": [
    {
      "source": "/careers/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(googlebot|bingbot|yandex|baiduspider|twitterbot|facebookexternalhit|embedly|prerender)"
        }
      ],
      "destination": "https://service.prerender.io/https://www.cfound.in/careers/$1?_prerender_token=HmkrZMemSTznfsK9UWL3"
    },
    {
      "source": "/careers/:slug",
      "destination": "/api/job/:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}